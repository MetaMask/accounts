{
  "customTypes": {
    "engines": {
      "path": "engines",
      "strategy": "versionsByName"
    },
    "packageManager": {
      "path": "packageManager",
      "strategy": "name@version"
    }
  },
  "semverGroups": [
    {
      "label": "use tilde range for some dependencies",
      "dependencies": [
        "eslint-plugin-import",
        "typescript"
      ],
      "range": "~"
    },
    {
      "label": "use exact versions for some dependencies",
      "dependencies": [
        "yarn"
      ],
      "range": ""
    },
    {
      "label": "use caret ranges everywhere else",
      "dependencies": [
        "**"
      ],
      "range": "^"
    }
  ],
  "versionGroups": [
    {
      "label": "ban workspace protocol dependencies",
      "specifierTypes": [
        "workspace-protocol"
      ],
      "isBanned": true
    },
    {
      "label": "local packages in peer dependencies use same-major range (ignored by version checks)",
      "dependencyTypes": [
        "peer"
      ],
      "dependencies": [
        "@metamask/account-**",
        "@metamask/hw-wallet-sdk",
        "@metamask/keyring-**",
        "@metamask/eth-**-keyring"
      ],
      "preferVersion": "sameRange"
    },
    {
      "label": "local packages must use the highest semver version",
      "dependencyTypes": [
        "!peer"
      ],
      "dependencies": [
        "@metamask/account-**",
        "@metamask/hw-wallet-sdk",
        "@metamask/keyring-**",
        "@metamask/eth-**-keyring"
      ],
      "policy": "highestSemver"
    }
  ]
}
